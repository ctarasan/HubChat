# ----------------------------
# Next.js app (Vercel) - browser-safe
# ----------------------------
# Optional. Used by app/page.tsx as default API base URL in the composer.
NEXT_PUBLIC_APP_BASE_URL=https://your-vercel-app.vercel.app

# ----------------------------
# Next.js app (Vercel) - server-only secrets
# ----------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional tenant mapping fallback for webhook routes.
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000

# Channel webhook / outbound adapter configuration (server-only)
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
FACEBOOK_PAGE_ACCESS_TOKEN=your-facebook-page-access-token
FACEBOOK_VERIFY_TOKEN=your-facebook-verify-token

# Outbound image upload + provider URL strategy (server-only)
# MESSAGE_IMAGE_BUCKET=message-images
# MESSAGE_IMAGE_URL_MODE=signed
# MESSAGE_IMAGE_SIGNED_URL_TTL_SEC=2592000

# Inbound image media strategy (server-only; worker uses these)
# INBOUND_MEDIA_BUCKET=inbound-media
# INBOUND_MEDIA_URL_MODE=public
# INBOUND_MEDIA_MAX_SIZE_MB=10

# ----------------------------
# Worker (Railway) variables are configured separately.
# See env/worker.low.env.template, env/worker.medium.env.template, env/worker.high.env.template
# ----------------------------
